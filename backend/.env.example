# Optional: Default Anthropic key if extension doesn't send one (users can set their own in extension)
# ANTHROPIC_API_KEY=sk-ant-...

# Required: Backend API key (for extension when not using sign-in)
BACKEND_API_KEY=your-secret-token

# Required for sign-in: secret used to sign JWTs (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# Optional: Google connector (OAuth). One sign-in gives Calendar, Gmail, Drive. Create a project at console.cloud.google.com, enable Calendar API (and Gmail/Drive if needed), create OAuth 2.0 credentials (Desktop).
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Optional: Port (default 3000)
PORT=3000

# Optional: Allowed WebSocket origins (comma-separated). Use chrome-extension:// for extension.
# Example: http://localhost:3000,chrome-extension://abcdefghijklmnop
ALLOWED_ORIGINS=*
